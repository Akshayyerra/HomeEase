generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id       String  @id @default(cuid())
  name     String
  email    String? @unique
  phone    String? @unique
  password String?

  role Role @default(CUSTOMER)

  // Bookings created by customer
  bookings Booking[] @relation("CustomerBookings")

  // Bookings assigned to worker
  assignedBookings Booking[] @relation("AssignedWorker")

  // Reviews written by customer
  customerReviews Review[] @relation("CustomerReviews")

  // Reviews received by worker
  workerReviews Review[] @relation("WorkerReviews")

  // Worker availability
  isOnline Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Booking {
  id        String   @id @default(cuid())

  service   String

  // NEW FIELD
  price     Int      @default(0)

  bookingAt DateTime
  address   String
  phone     String

  status String @default("PENDING")

  paymentId     String?
  paymentStatus String? @default("PENDING")

  latitude  Float?
  longitude Float?

  workerLatitude  Float?
  workerLongitude Float?

  userId String
  user   User @relation("CustomerBookings", fields: [userId], references: [id])

  workerId String?
  worker   User? @relation("AssignedWorker", fields: [workerId], references: [id])

  // One review per booking
  review Review?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Paste {
  id        String    @id @default(cuid())
  content   String
  views     Int       @default(0)
  maxViews  Int?
  expiresAt DateTime?
  createdAt DateTime  @default(now())
}

model Review {
  id String @id @default(cuid())

  rating  Int
  comment String?

  customerId String
  workerId   String
  bookingId  String @unique

  customer User @relation("CustomerReviews", fields: [customerId], references: [id])
  worker   User @relation("WorkerReviews", fields: [workerId], references: [id])

  booking Booking @relation(fields: [bookingId], references: [id])

  createdAt DateTime @default(now())
}

enum Role {
  CUSTOMER
  PROVIDER
  ADMIN
}