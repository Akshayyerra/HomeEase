generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id       String  @id @default(cuid())
  name     String
  email    String? @unique
  phone    String? @unique
  password String?

  role Role @default(CUSTOMER)

  // Bookings created by customer
  bookings Booking[] @relation("CustomerBookings")

  // Bookings assigned to worker
  assignedBookings Booking[] @relation("AssignedWorker")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Booking {
  id        String   @id @default(cuid())
  service   String
  bookingAt DateTime
  address   String
  phone     String

  status String @default("PENDING")

  paymentId     String?
  paymentStatus String? @default("PENDING")

  latitude  Float?
  longitude Float?

  workerLatitude  Float?
  workerLongitude Float?

  userId String
  user   User   @relation("CustomerBookings", fields: [userId], references: [id])

  workerId String?
  worker   User?   @relation("AssignedWorker", fields: [workerId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Paste {
  id        String    @id @default(cuid())
  content   String
  views     Int       @default(0)
  maxViews  Int?
  expiresAt DateTime?
  createdAt DateTime  @default(now())
}

enum Role {
  CUSTOMER
  PROVIDER
  ADMIN
}
